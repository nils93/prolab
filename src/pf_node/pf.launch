<launch>

  <!-- Simulationszeit aktivieren -->
  <param name="use_sim_time" value="true"/>

  <!-- Fester statischer TF zwischen map und odom -->
  <node pkg="tf2_ros" type="static_transform_publisher" name="map_to_odom"
        args="0 0 0 0 0 0 map odom"/>

  <!-- Map Server -->
  <node pkg="map_server" type="map_server" name="map_server"
        args="$(find pf_node)/maps/my_map.yaml" output="screen"/>

  <!-- Partikel-Filter -->
  <node pkg="pf_node" type="pf_node" name="pf_node" output="screen">
    <param name="use_sim_time" value="true"/>
    <remap from="odom" to="/odom"/>
  </node>

</launch>
